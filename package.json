{
  "name": "removebg-pro-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "build": "next build",
    "build:cf": "npm install --legacy-peer-deps && next build",
    "pages:build": "npm install --legacy-peer-deps && npx @cloudflare/next-on-pages",
    "cf-build": "npm install --legacy-peer-deps && npx @cloudflare/next-on-pages",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "eslint",
    "preview": "npm run pages:build && wrangler pages dev",
    "deploy": "npm run pages:build && wrangler pages deploy"
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "next": "15.1.6",
    "next-auth": "^5.0.0-beta.30",
    "onnxruntime-web": "^1.24.3",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^3"
  }
}
